# Excalibur Environment Variables
#
# This file documents the environment variables currently supported by
# Excalibur core and official plugins. Copy values into your deployment
# environment or systemd service configuration as needed.
#
# Excalibur automatically loads a repository-root `.env` file at process
# startup for both the sniffer and dashboard, without overriding variables
# that are already present in the environment.

# ----------------------------------------------------------------------
# Core ERL Debugging
# ----------------------------------------------------------------------

# Enable verbose logging for DNS events processed by the ERL signature engine.
# Accepted truthy values: 1, true, yes, on
EXCALIBUR_ERL_DEBUG_DNS=

# Enable verbose rule-evaluation logging in the ERL signature engine.
# Accepted truthy values: 1, true, yes, on
EXCALIBUR_ERL_DEBUG_RULES=

# Enable verbose ERL alert-generation logging.
# Accepted truthy values: 1, true, yes, on
EXCALIBUR_ERL_DEBUG_ALERTS=

# ----------------------------------------------------------------------
# AbuseIPDB Plugin
# ----------------------------------------------------------------------

# Optional API key for the AbuseIPDB proof-of-concept plugin.
# If unset, the plugin loads but skips remote lookups.
ABUSEIPDB_API_KEY=

# ----------------------------------------------------------------------
# AlienVault OTX Plugin
# ----------------------------------------------------------------------

# Optional API key for the OTX Threat Intel plugin.
# If unset, the plugin loads and uses cached indicators only.
OTX_API_KEY=

# Maximum number of most recent OTX pulses to process during a refresh.
OTX_MAX_PULSES=100

# How old the local OTX cache may be before a refresh is attempted at startup.
OTX_REFRESH_HOURS=24

# Maximum number of indicators to retain from OTX during refresh.
OTX_MAX_INDICATORS=100000

# ----------------------------------------------------------------------
# Wazuh Forwarder Plugin
# ----------------------------------------------------------------------

# Optional runtime switch for the Wazuh forwarder plugin.
# If unset, the plugin defaults to enabled when its plugin.yaml is enabled.
EXCALIBUR_WAZUH_ENABLED=

# Transport for forwarding Excalibur alerts to Wazuh.
# Supported values: localfile, tcp
EXCALIBUR_WAZUH_TRANSPORT=localfile

# Local JSONL path used by the default localfile transport.
EXCALIBUR_WAZUH_LOG_PATH=/var/ossec/logs/excalibur-alerts.log

# Agent name included in forwarded Wazuh records.
# Defaults to the local hostname if unset.
EXCALIBUR_WAZUH_AGENT_NAME=

# Timeout used by the TCP transport.
EXCALIBUR_WAZUH_TIMEOUT_SECONDS=5

# TCP transport destination host.
EXCALIBUR_WAZUH_TCP_HOST=

# TCP transport destination port.
EXCALIBUR_WAZUH_TCP_PORT=
